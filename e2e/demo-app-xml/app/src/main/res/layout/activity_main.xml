<?xml version="1.0" encoding="utf-8"?>
<!-- Epic M / TD-129 (Wave 21): switched from 1-col ScrollView+LinearLayout
     to 2-col GridLayout mirroring Compose demo's LazyVerticalGrid(Fixed(2)).
     Reason: the walker only emits on-screen views; with 26 buttons in a
     single column, T19+ rendered off-screen at app launch, so home-tap
     steps for T19/T20/T22/T25/T26 failed with "element not found". 2-col
     grid keeps all 26 buttons within the visible region on a standard
     emulator viewport. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:padding="8dp">

        <Button android:id="@+id/t1_launch"  android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T1 Launch" />
        <Button android:id="@+id/t2_launch"  android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T2 Type" />
        <Button android:id="@+id/t3_launch"  android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T3 Tap" />
        <Button android:id="@+id/t4_launch"  android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T4 Navigate" />
        <Button android:id="@+id/t5_launch"  android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T5 Kbd Dismiss" />
        <Button android:id="@+id/t6_launch"  android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T6 Secure Field" />
        <Button android:id="@+id/t7_launch"  android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T7 Dialog" />
        <Button android:id="@+id/t8_launch"  android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T8 Scroll" />
        <Button android:id="@+id/t9_launch"  android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T9 Wait" />
        <Button android:id="@+id/t10_launch" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T10 Mock URL" />
        <Button android:id="@+id/t11_launch" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T11 Deep Nav" />
        <Button android:id="@+id/t12_launch" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T12 Paste" />
        <Button android:id="@+id/t13_launch" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T13 Login" />
        <Button android:id="@+id/t14_launch" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T14 Screen" />
        <Button android:id="@+id/t15_launch" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T15 State" />
        <Button android:id="@+id/t16_launch" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T16 Text Equal" />
        <Button android:id="@+id/t17_launch" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T17 Animations" />
        <Button android:id="@+id/t18_launch" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T18 Tabs" />
        <Button android:id="@+id/t19_launch" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T19 Sheet" />
        <Button android:id="@+id/t20_launch" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T20 Refresh" />
        <Button android:id="@+id/t21_launch" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T21 Press Back" />
        <Button android:id="@+id/t22_launch" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T22 Long Press" />
        <Button android:id="@+id/t23_launch" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T23 Capture" />
        <Button android:id="@+id/t24_launch" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T24 Screenshot" />
        <Button android:id="@+id/t25_launch" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T25 Scroll" />
        <Button android:id="@+id/t26_launch" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="T26 Hide Show" />
    </GridLayout>
</ScrollView>
