<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="16dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T15 State" />
    <Button android:id="@+id/t15_action"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Action Button" />
    <TextView android:id="@+id/t15_taps"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="taps=0" />
    <Button android:id="@+id/t15_toggle"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Toggle Action" />
    <TextView android:id="@+id/t15_state_label"
        android:layout_width="wrap_content" android:layout_height="wrap_content" />
</LinearLayout>
