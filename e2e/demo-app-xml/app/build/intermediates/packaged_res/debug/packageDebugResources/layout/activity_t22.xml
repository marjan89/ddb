<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="16dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T22 Long Press" />
    <TextView android:id="@+id/t22_press_target"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="T22 Press Target"
        android:contentDescription="T22 Press Target"
        android:background="#CCCCCC"
        android:padding="16dp"
        android:longClickable="true" />
    <TextView android:id="@+id/t22_state"
        android:layout_width="wrap_content" android:layout_height="wrap_content" />
</LinearLayout>
