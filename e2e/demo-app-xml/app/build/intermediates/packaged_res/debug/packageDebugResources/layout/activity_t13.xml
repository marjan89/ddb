<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="16dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T13 Login" />
    <TextView android:id="@+id/t13_primary"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="T13 Locked" />
    <TextView android:id="@+id/t13_error"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Invalid credentials"
        android:contentDescription="Invalid credentials"
        android:visibility="gone" />
    <Button android:id="@+id/t13_reset"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="T13 Reset" />
</LinearLayout>
